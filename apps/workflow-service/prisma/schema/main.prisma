generator client {
    provider = "prisma-client"
    output   = "../../generated/prisma"
    moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
}

model ProcessDefinition {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  versions ProcessVersion[]

  @@map("process_definitions")
}

model ProcessVersion {
  id           String   @id @default(cuid())
  definitionId String
  version      Int
  status       String   // ProcessVersionStatus e.g. DRAFT, PUBLISHED
  graph        Json
  createdAt    DateTime @default(now())

  definition ProcessDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  instances  ProcessInstance[]

  @@unique([definitionId, version])
  @@map("process_versions")
}

model ProcessInstance {
  id              String   @id @default(cuid())
  definitionId    String
  versionId       String
  businessKey     String?
  organizationId  String
  status          String   // ProcessInstanceStatus e.g. RUNNING, COMPLETED, FAILED
  currentNodeCode String?
  variables       Json?
  startedBy       String
  startedAt       DateTime @default(now())
  endedAt         DateTime?

  version     ProcessVersion       @relation(fields: [versionId], references: [id])
  tasks       WorkflowTask[]
  transitions WorkflowTransition[]
  events      WorkflowEvent[]

  @@map("process_instances")
}

model WorkflowTask {
  id           String   @id @default(cuid())
  instanceId   String
  nodeCode     String
  title        String
  assigneeId   String?
  assigneeUnit String?
  status       String   // TaskStatus e.g. PENDING, COMPLETED, CANCELED
  dueAt        DateTime?
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  instance ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_tasks")
}

model WorkflowTransition {
  id           String   @id @default(cuid())
  instanceId   String
  fromNodeCode String?
  toNodeCode   String
  action       String
  performedBy  String
  performedAt  DateTime @default(now())
  comment      String?  @db.Text
  payload      Json?

  instance ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_transitions")
}

model WorkflowEvent {
  id           String   @id @default(cuid())
  instanceId   String
  eventType    String
  payload      Json
  status       String   // EventStatus e.g. PENDING, PROCESSED, FAILED
  retryCount   Int      @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime @default(now())

  instance ProcessInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_events")
}

model IntegrationConnection {
  id          String   @id @default(uuid())
  name        String   // VD: Cổng DVC Quốc Gia
  code        String   @unique 
  description String?  @db.Text
  protocol    String   @default("REST") // REST, SOAP, GRAPHQL, GRPC
  baseUrl     String   
  authType    String   @default("NONE") // NONE, BASIC, BEARER, OAUTH2, API_KEY
  authConfig  Json?    // Cấu hình username/password, token_url, client_id, v.v.
  headers     Json?    // Các header tĩnh
  endpoints   Json?    // Danh sách các endpoints chi tiết (path, method)
  metadata    Json?    // Chứa WSDL URL (nếu SOAP), OpenAPI spec, v.v.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("integration_connections")
}

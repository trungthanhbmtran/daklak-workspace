generator client {
    provider = "prisma-client"
    output   = "../../generated/prisma"
    moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
}

model WorkflowDefinition {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  version     Int      @default(1)
  status      String   @default("Draft") // Draft | Published | Archived
  description String?  @db.Text
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  nodes     WorkflowNode[]
  edges     WorkflowEdge[]
  variables WorkflowVariable[]
  instances WorkflowInstance[]

  @@map("workflow_definitions")
}

model WorkflowNode {
  id         String @id @default(uuid())
  workflowId String
  nodeKey    String // Unique key inside the workflow (e.g. node_1)
  type       String // StartEvent, UserTask, ServiceTask, etc.
  name       String
  x          Float
  y          Float
  properties Json?
  order      Int    @default(0)

  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  assignments AssignmentRule[]
  actions     NodeAction[]

  // For WorkflowEdge relations
  sourceEdges WorkflowEdge[] @relation("SourceNode")
  targetEdges WorkflowEdge[] @relation("TargetNode")

  @@map("workflow_nodes")
}

model WorkflowEdge {
  id           String  @id @default(uuid())
  workflowId   String
  sourceNodeId String
  targetNodeId String
  condition    String? @db.Text
  properties   Json?
  priority     Int     @default(0)
  defaultFlow  Boolean @default(false)

  workflow   WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode WorkflowNode       @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode WorkflowNode       @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@map("workflow_edges")
}

model AssignmentRule {
  id     String @id @default(uuid())
  nodeId String
  type   String // creator, role, position, user, etc.
  value  String

  node WorkflowNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@map("assignment_rules")
}

model NodeAction {
  id              String @id @default(uuid())
  nodeId          String
  actionType      String // Command, Event
  service         String
  action          String
  payloadTemplate Json?
  order           Int    @default(0)

  node WorkflowNode @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@map("node_actions")
}

model WorkflowVariable {
  id           String @id @default(uuid())
  workflowId   String
  key          String
  type         String
  defaultValue Json?

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@map("workflow_variables")
}

model WorkflowInstance {
  id            String   @id @default(uuid())
  workflowId    String
  version       Int      @default(1)
  entityType    String   @default("TASK")
  entityId      String   @default("UNKNOWN")
  currentNodeId String?
  status        String   // Running, Completed, Failed, Pending
  variables     Json?
  startedAt     DateTime @default(now())
  finishedAt    DateTime?

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id])
  tasks    WorkflowTask[]

  @@map("workflow_instances")
}

model WorkflowTask {
  id          String    @id @default(uuid())
  instanceId  String
  nodeId      String
  assigneeId  String?
  status      String    // Pending, Completed, Canceled
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_tasks")
}

model IntegrationConnection {
  id          String   @id @default(uuid())
  name        String   // Tên hệ thống (VD: Cổng DVC Quốc Gia)
  code        String   @unique // Mã liên thông (VD: DVCQG_SYNC)
  description String?  @db.Text
  type        String   @default("REST") // REST hoặc SOAP
  baseUrl     String   
  authConfig  Json?    
  headers     Json?    
  endpoints   Json?    
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("integration_connections")
}


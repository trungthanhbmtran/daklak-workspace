# Copy sang .env và sửa theo môi trường của bạn.
# RabbitMQ – bắt buộc. Trong K8s pod dùng ConfigMap app-common (đã có RABBITMQ_URL, NOTIFICATION_QUEUE).
# Chạy local + K8s RabbitMQ: port-forward "kubectl port-forward -n stc svc/rabbitmq-service 5672:5672" rồi dùng localhost bên dưới.
# Hoặc NodePort (AMQP 30672, Management 31672): amqp://guest:guest@<node-ip>:30672
RABBITMQ_URL=amqp://guest:guest@localhost:5672
NOTIFICATION_QUEUE=notifications

# Retry khi kết nối RabbitMQ (tùy chọn)
# RABBITMQ_CONNECT_ATTEMPTS=5
# RABBITMQ_RETRY_DELAY_MS=3000

# Kênh mặc định (console = log ra terminal, không cần cấu hình thêm)
NOTIFICATION_DEFAULT_CHANNEL=console

# --- Email (khi dùng kênh email) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM=your-app@gmail.com
# SMTP_USER=your-app@gmail.com
# SMTP_PASSWORD=your-app-password

# --- Telegram / Zalo / Facebook: thêm token tương ứng nếu dùng ---

generator client {
  provider   = "prisma-client-js"
  // Ép kiểu engine về library để chạy ổn định trên Docker/Node.js 
  // mà không cần Driver Adapter phức tạp
  engineType = "library" 
}

datasource db {
  provider = "mysql"
  // URL lấy từ biến môi trường giúp Prisma Client tự nạp cấu hình khi chạy
}
# ==========================================
# 1️⃣ Dependency Stage
# ==========================================
FROM node:22-alpine AS deps
WORKDIR /app

RUN apk add --no-cache openssl

COPY apps/api-gateway/package*.json ./
RUN npm ci

# ==========================================
# 2️⃣ Builder Stage
# ==========================================
FROM node:22-alpine AS builder
WORKDIR /app

RUN apk add --no-cache openssl

COPY --from=deps /app/node_modules ./node_modules
COPY apps/api-gateway/ ./
COPY shared/protos ./shared/protos

# Build the app
RUN npx prisma generate --schema=./prisma/schema.prisma
RUN npm run build

# ==========================================
# 3️⃣ Production Runner Stage
# ==========================================
FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN apk add --no-cache openssl

# Security: Create user and group before copying files
RUN addgroup -S app && adduser -S app -G app

COPY --chown=app:app apps/api-gateway/package*.json ./
RUN npm ci --omit=dev

COPY --chown=app:app --from=builder /app/dist ./dist
# Note: Copied to dist/generated/client to resolve relative imports (../../../generated/client)
COPY --chown=app:app --from=builder /app/generated/client ./dist/generated/client
COPY --chown=app:app --from=builder /app/shared/protos ./protos
COPY --chown=app:app --from=builder /app/prisma.config.ts ./prisma.config.ts
COPY --chown=app:app --from=builder /app/prisma ./prisma

ENV PROTO_PATH=/app/protos

USER app

EXPOSE 8080
CMD ["node", "dist/src/main.js"]
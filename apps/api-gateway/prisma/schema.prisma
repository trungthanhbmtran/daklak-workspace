// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "mysql"
}

model ApiPermission {
  id          String   @id @default(uuid())
  path        String
  method      String
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceEndpoint {
  id          String   @id @default(uuid())
  serviceName String
  endpoint    String
  status      String   @default("ACTIVE")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LgspIntegrationConfig {
  id             String    @id @default(uuid())
  name           String
  serviceCode    String    @unique
  apiUrl         String
  
  // Auth Config
  authType       String    @default("NONE") // NONE, STATIC, LOGIN_ENDPOINT
  authUrl        String?
  authPayload    Json?
  tokenPath      String?
  cachedToken    String?   @db.Text
  tokenExpiresAt DateTime?

  // Request Config
  requestMethod  String    @default("GET")
  requestParams  Json?

  // Display Config
  displayType    String    @default("RAW") // RAW, TABLE, CHART_BAR, CHART_PIE
  chartConfig    Json?

  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model GatewayConfig {
  id              String   @id @default(uuid())
  name            String   @default("Default Gateway")
  provider        String   @default("NGINX") // NGINX, TRAEFIK, HAPROXY
  
  httpPort        Int      @default(80)
  httpsPort       Int      @default(443)
  
  enableHttps     Boolean  @default(false)
  sslCert         String?  @db.Text
  sslKey          String?  @db.Text

  rawConfig       String?  @db.Text
  
  isActive        Boolean  @default(true)
  version         Int      @default(1)

  routes          GatewayRoute[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GatewayRoute {
  id              String   @id @default(uuid())
  gatewayId       String
  gateway         GatewayConfig @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  
  path            String
  targetService   String
  stripPrefix     Boolean  @default(false)
  
  rateLimit       Int?
  timeout         Int?

  order           Int      @default(0)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

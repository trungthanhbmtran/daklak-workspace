model AdministrativeProcedure {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  category     String   // e.g. "ho-tich", "chung-thuc"
  description  String?  @db.Text
  duration     String   // e.g. "3 ngày làm việc"
  fee          String   @default("Miễn phí")
  requiredDocs String   @db.Text // Store list as JSON array of strings
  steps        String   @db.Text // Store list as JSON array of strings
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([code])
  @@map("administrative_procedures")
}

model OneStopDossier {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. "DK-2026-888"
  senderName  String   @map("sender_name")
  receiveDate DateTime @map("receive_date")
  dueDate     DateTime @map("due_date")
  status      String   @default("RECEIVED") // RECEIVED, PROCESSING, RESOLVED, RETURNED
  currentStep Int      @default(1) @map("current_step") // 1 to 4
  stepDetails String?  @db.Text @map("step_details") // JSON array of step timeline
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([status])
  @@map("one_stop_dossiers")
}

model DossierComponent {
  id          String   @id @default(uuid())
  dossierId   String   @map("dossier_id")
  name        String
  isRequired  Boolean  @default(true) @map("is_required")
  status      String   @default("MISSING") // VALID, MISSING, PENDING_REVIEW
  fileUrl     String?  @map("file_url")
  source      String?  // UPLOAD, CABINET
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([dossierId])
  @@map("dossier_components")
}

model DocumentCabinet {
  id          String   @id @default(uuid())
  userId      String?  @map("user_id") // Nếu là tủ cá nhân
  orgId       String?  @map("org_id")  // Nếu là tủ cơ quan
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type") // pdf, excel, image, etc.
  fileSize    Int      @map("file_size") // bytes
  tags        String   @default("[]") // JSON array
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([orgId])
  @@map("document_cabinets")
}

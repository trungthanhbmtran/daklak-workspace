model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  type        String   // DOCUMENT_TYPE, DOCUMENT_FIELD
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documentsByType  Document[] @relation("DocumentType")
  documentsByField Document[] @relation("DocumentField")

  @@index([type])
}

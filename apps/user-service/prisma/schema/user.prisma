model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  username        String?           @unique
  fullName        String?           @map("full_name")
  phoneNumber     String?           @map("phone_number")
  avatarUrl       String?           @map("avatar_url")
  cccd            String?           @map("cccd")
  employeeCode    String?           @map("employee_code")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  UserToUserGroup UserToUserGroup[]
  accounts        Account[]
  credential      Credential?
  refreshTokens   RefreshToken[]
  jobPositions    JobPosition[]
  roles           Role[]            @relation("RoleToUser")

  @@map("users")
}

model JobPosition {
  id             Int              @id @default(autoincrement())
  userId         Int              @map("user_id")
  unitId         Int              @map("unit_id")
  jobTitleId     Int              @map("job_title_id")
  isPrimary      Boolean          @default(false) @map("is_primary")
  isUnitLeader   Boolean          @default(false) @map("is_unit_leader")
  isDeputyLeader Boolean          @default(false) @map("is_deputy_leader")
  startDate      DateTime         @default(now()) @map("start_date")
  endDate        DateTime?        @map("end_date")
  jobTitle       JobTitle         @relation(fields: [jobTitleId], references: [id])
  unit           OrganizationUnit @relation(fields: [unitId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([jobTitleId], map: "job_positions_job_title_id_fkey")
  @@index([unitId], map: "job_positions_unit_id_fkey")
  @@index([userId], map: "job_positions_user_id_fkey")
  @@map("job_positions")
}

model UserGroup {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  UserToUserGroup UserToUserGroup[]
  roles           Role[]            @relation("RoleToUserGroup")

  @@map("user_groups")
}

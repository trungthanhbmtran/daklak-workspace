model Category {
  id                  Int                   @id @default(autoincrement())
  groupCode           String                @map("group_code")
  code                String
  order               Int                   @default(0)
  isActive            Boolean               @default(true) @map("is_active")
  unitDomains         UnitDomain[]
  unitGeographicAreas UnitGeographicArea[]
  group               CategoryGroup         @relation(fields: [groupCode], references: [code])
  translations        CategoryTranslation[]

  @@unique([groupCode, code])
  @@index([groupCode])
  @@map("sys_categories")
}

model CategoryTranslation {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  langCode    String   @map("lang_code")
  name        String   @db.Text
  description String?  @db.Text
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, langCode])
  @@index([langCode])
  @@map("sys_category_translations")
}

model CategoryGroup {
  code       String     @id
  name       String
  order      Int        @default(0)
  isActive   Boolean    @default(true)
  categories Category[]

  @@map("sys_category_groups")
}

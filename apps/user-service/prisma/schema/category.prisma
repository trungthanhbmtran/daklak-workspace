model Category {
  id          Int      @id @default(autoincrement())
  group       String   @map("group_code") 
  code        String   
  order       Int      @default(0) 
  
  isSystem    Boolean  @default(false) @map("is_system") 
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  unitDomains             UnitDomain[]      
  jobTitlesDomain         JobTitle[]         @relation("JobTitleDomain") 
  jobTitlesGeographicArea JobTitle[]         @relation("JobTitleGeographicArea") 
  staffingSlotsGeographicArea StaffingSlot[]  @relation("StaffingSlotGeographicArea") 
  staffingSlotGeographicAreas StaffingSlotGeographicArea[] @relation("StaffingSlotGeographicAreas")
  staffingSlotDomains         StaffingSlotDomain[]  
  translations            CategoryTranslation[]

  @@unique([group, code]) 
  @@index([group])        
  @@map("sys_categories")
}

model CategoryTranslation {
  id          Int      @id @default(autoincrement())
  categoryId  Int      @map("category_id")
  langCode    String   @map("lang_code")
  name        String   @db.Text
  description String?  @db.Text

  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, langCode])
  @@index([langCode])
  @@map("sys_category_translations")
}

model CategoryGroup {
  code        String   @id
  name        String
  description String?
  order       Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("sys_category_groups")
}
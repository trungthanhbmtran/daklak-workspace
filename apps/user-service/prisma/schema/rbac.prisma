model Role {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String?
  description String?
  users       User[]
  groups      UserGroup[]
  policies    Policy[]

  @@map("roles")
}

model Policy {
  id         Int    @id @default(autoincrement())
  resourceId Int    @map("resource_id")
  action     String
  effect     String @default("ALLOW")
  conditions Json?

  roles    Role[]
  resource Resource @relation(fields: [resourceId], references: [id])

  @@map("policies")
}

model Resource {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  serviceCode String?      @map("service_code")
  policies    Policy[]

  @@map("resources")
}

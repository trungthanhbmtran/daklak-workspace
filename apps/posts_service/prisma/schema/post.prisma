enum PostStatus {
  draft
  pending
  editing
  approved
  published
  rejected
  archived
}

model Post {
  id              String         @id @default(uuid()) @db.Char(36)
  title           String         @db.VarChar(255)
  content         String?        @db.LongText
  contentJson     Json?          @map("content_json")
  description     String?        @db.Text
  slug            String         @unique @db.VarChar(255)
  authorId        String         @map("author_id") @db.Char(36)
  categoryId      String?        @map("category_id") @db.Char(36)
  reviewerId      String?        @map("reviewer_id") @db.Char(36)
  moderationNote  String?        @map("moderation_note") @db.Text
  language        String         @default("vi") @db.VarChar(10)
  status          PostStatus     @default(draft)
  thumbnail       String?        @db.VarChar(255)
  isFeatured      Boolean        @default(false) @map("is_featured")
  isNotification  Boolean        @default(false) @map("is_notification")
  viewCount       Int            @default(0) @map("view_count")
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  category        Category?      @relation(fields: [categoryId], references: [id])
  tags            Tag[]          @relation("PostTags")
  translations    PostTranslate[]
  variables       Variable[]

  @@index([categoryId, status])
  @@index([authorId])
  @@index([status, publishedAt])
  @@index([isFeatured, status])
  @@index([isNotification, status])
  @@index([title])
  @@index([language])
  @@map("posts")
}

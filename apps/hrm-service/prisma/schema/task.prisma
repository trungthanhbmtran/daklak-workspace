model Task {
  id          Int     @id @default(autoincrement())
  parentId    Int?    @map("parent_id")
  title       String  @map("title")
  description String? @db.Text

  status       String  @default("TODO")
  priority     String  @default("MEDIUM")
  progress     Float   @default(0) @map("progress")
  rejectReason String? @map("reject_reason") @db.Text

  startDate   DateTime? @map("start_date") @db.Date
  dueDate     DateTime? @map("due_date") @db.Date
  completedAt DateTime? @map("completed_at")
  isCompleted Boolean   @default(false) @map("is_completed")

  isDeadlineWarned Boolean @default(false) @map("is_deadline_warned")
  isRiskWarned     Boolean @default(false) @map("is_risk_warned")

  domainId        Int? @map("domain_id")
  monitoredUnitId Int? @map("monitored_unit_id")
  planId          Int? @map("plan_id")

  workflowInstId String? @map("workflow_instance_id")
  conversationId String? @map("conversation_id")
  metadata       Json?   @map("metadata")

  creatorEmployeeCode String?  @map("creator_employee_code")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  isDeleted           Boolean  @default(false) @map("is_deleted")

  plan        MasterPlan?     @relation(fields: [planId], references: [id])
  kpiSettings TaskKpiSetting?

  participants TaskParticipant[]
  attachments  TaskAttachment[]
  histories    TaskHistory[]
  steps        TaskStep[]

  ancestors   TaskClosure[] @relation("TaskClosureDescendant")
  descendants TaskClosure[] @relation("TaskClosureAncestor")

  @@index([dueDate])
  @@index([status, dueDate])
  @@index([isCompleted, dueDate])
  @@index([parentId])
  @@index([planId])
  @@index([createdAt])
  @@map("tasks")
}

model TaskStep {
  id           Int       @id @default(autoincrement())
  taskId       Int       @map("task_id")
  title        String    @map("title")
  status       String    @default("TODO") // TODO, COMPLETED
  order        Int       @default(0)
  assigneeCode String?   @map("assignee_code")
  baseScore    Float     @default(0) @map("base_score")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  isDeleted    Boolean   @default(false) @map("is_deleted")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_steps")
}

model TaskAttachment {
  id         Int      @id @default(autoincrement())
  taskId     Int      @map("task_id")
  documentId String   @map("document_id")
  type       String   @default("REFERENCE")
  createdAt  DateTime @default(now()) @map("created_at")
  isDeleted  Boolean  @default(false) @map("is_deleted")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_attachments")
}

enum TaskRole {
  OWNER
  ASSIGNEE
  APPROVER
  COORDINATOR
  FOLLOWER
}

model TaskParticipant {
  taskId                 Int      @map("task_id")
  employeeCode           String   @map("employee_code")
  participantRole        TaskRole @map("participant_role")
  assignedAt             DateTime @default(now()) @map("assigned_at")
  contributionPercentage Float    @default(100.0) @map("contribution_percentage")

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee Employee @relation("EmployeeTasks", fields: [employeeCode], references: [employeeCode])

  @@id([taskId, employeeCode, participantRole])
  @@map("task_participants")
}

model TaskClosure {
  ancestorId   Int @map("ancestor_id")
  descendantId Int @map("descendant_id")
  depth        Int @map("depth")

  ancestor   Task @relation("TaskClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Task @relation("TaskClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@map("task_closure")
}


model TaskHistory {
  id        Int      @id @default(autoincrement())
  taskId    Int      @map("task_id")
  action    String   @map("action")
  actorCode String?  @map("actor_code")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_histories")
}

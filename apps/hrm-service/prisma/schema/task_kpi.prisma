model Task {
  id             Int       @id @default(autoincrement())
  title          String    @map("title")
  description    String?   @db.Text
  
  // Decoupled Identity: Dùng employee_code (String) làm Integration Key thay vì khóa ngoại cứng (Int)
  assigneeCode   String    @map("assignee_code") 
  assignerCode   String    @map("assigner_code")
  
  status         String    @default("TODO") // DRAFT, TODO, IN_PROGRESS, REVIEWING, DONE, OVERDUE, CANCELLED
  priority       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  
  // KPI Scoring Parameters
  baseScore      Float?    @map("base_score")
  weight         Float?    @map("weight")
  scoringMethod  String    @default("MANUAL") @map("scoring_method") // MANUAL, AUTO_DEADLINE, AUTO_RESULT
  bonusPerDay    Float?    @map("bonus_per_day")
  penaltyPerDay  Float?    @map("penalty_per_day")
  supervisorCode String?   @map("supervisor_code")

  // Document-driven Workflow: Lưu danh sách ID văn bản liên quan (Evidence/Source)
  documentIds    Json?     @map("document_ids") // Lưu array of strings/UUIDs
  workflowInstId String?   @map("workflow_instance_id")

  dueDate        DateTime? @map("due_date") @db.Date
  completionDate DateTime? @map("completion_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  planId         Int?      @map("plan_id")
  plan           MasterPlan? @relation(fields: [planId], references: [id])

  // Quan hệ tới bảng Employee được thực hiện lỏng lẻo qua employeeCode
  assignee       Employee? @relation("TaskAssignee", fields: [assigneeCode], references: [employeeCode])
  assigner       Employee? @relation("TaskAssigner", fields: [assignerCode], references: [employeeCode])
  supervisor     Employee? @relation("TaskSupervisor", fields: [supervisorCode], references: [employeeCode])

  @@map("tasks")
}

model MasterPlan {
  id          Int       @id @default(autoincrement())
  title       String    @map("title")
  description String?   @db.Text
  type        String    @default("SMART_GOAL") // SMART_GOAL, OKR, MASTER_PLAN
  
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  status      String    @default("ACTIVE") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  
  // Document Reference (Nghị quyết, Chủ trương sinh ra MasterPlan này)
  documentId  String?   @map("document_id")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tasks       Task[]

  @@map("master_plans")
}

model KpiPeriod {
  id          Int             @id @default(autoincrement())
  name        String          @map("name") // e.g. "Tháng 5/2026"
  startDate   DateTime        @map("start_date") @db.Date
  endDate     DateTime        @map("end_date") @db.Date
  evaluations KpiEvaluation[]

  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("kpi_periods")
}

model KpiCriteria {
  id            Int                   @id @default(autoincrement())
  name          String                @map("name")
  description   String?               @db.Text
  weight        Float                 @default(1.0) @map("weight")
  baseScore     Float?                @map("base_score")
  scoringMethod String                @default("MANUAL") @map("scoring_method")
  categoryId    Int?                  @map("category_id")
  
  details       KpiEvaluationDetail[]

  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@map("kpi_criteria")
}

model KpiEvaluation {
  id          Int                   @id @default(autoincrement())
  employeeCode String                 @map("employee_code") // Đổi sang Code để decouple
  periodId    Int                   @map("period_id")
  totalScore  Float?                @map("total_score")
  status      String                @default("DRAFT") // DRAFT, COMPUTING, SUBMITTED, APPROVED
  reviewerCode String?                @map("reviewer_code")

  employee    Employee              @relation("KpiEmployee", fields: [employeeCode], references: [employeeCode])
  reviewer    Employee?             @relation("KpiReviewer", fields: [reviewerCode], references: [employeeCode])
  period      KpiPeriod             @relation(fields: [periodId], references: [id])
  details     KpiEvaluationDetail[]

  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@map("kpi_evaluations")
}

model KpiEvaluationDetail {
  id            Int           @id @default(autoincrement())
  evaluationId  Int           @map("evaluation_id")
  criteriaId    Int           @map("criteria_id")
  selfScore     Float?        @map("self_score")
  reviewerScore Float?        @map("reviewer_score")
  notes         String?       @db.Text

  evaluation    KpiEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criteria      KpiCriteria   @relation(fields: [criteriaId], references: [id])

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("kpi_evaluation_details")
}

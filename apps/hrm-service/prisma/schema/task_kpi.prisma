model Task {
  id          Int     @id @default(autoincrement())
  parentId    Int?    @map("parent_id")
  title       String  @map("title")
  description String? @db.Text

  status      String  @default("TODO")
  priority    String  @default("MEDIUM")
  progress    Float   @default(0) @map("progress")
  rejectReason String? @map("reject_reason") @db.Text

  startDate   DateTime? @map("start_date") @db.Date
  dueDate     DateTime? @map("due_date") @db.Date
  completedAt DateTime? @map("completed_at")

  isDeadlineWarned Boolean @default(false) @map("is_deadline_warned")
  isRiskWarned     Boolean @default(false) @map("is_risk_warned")

  domainId        Int? @map("domain_id")
  monitoredUnitId Int? @map("monitored_unit_id")
  planId          Int? @map("plan_id")

  workflowInstId String? @map("workflow_instance_id")
  metadata       Json?   @map("metadata")

  creatorEmployeeCode String? @map("creator_employee_code")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  plan         MasterPlan?      @relation(fields: [planId], references: [id])
  kpiSettings  TaskKpiSetting?
  
  participants TaskParticipant[]
  attachments  TaskAttachment[]
  comments     TaskComment[]
  
  ancestors    TaskClosure[]    @relation("TaskClosureDescendant")
  descendants  TaskClosure[]    @relation("TaskClosureAncestor")

  @@index([dueDate])
  @@index([status, dueDate])
  @@index([parentId])
  @@index([planId])
  @@index([createdAt])
  @@map("tasks")
}

model TaskKpiSetting {
  taskId        Int    @id @map("task_id")
  baseScore     Float? @map("base_score")
  weight        Float? @map("weight")
  scoringMethod String @default("MANUAL") @map("scoring_method")

  isCrossDomain         Boolean @default(false) @map("is_cross_domain")
  crossDomainMultiplier Float   @default(1.0) @map("cross_domain_multiplier")

  bonusPerDay   Float? @map("bonus_per_day")
  penaltyPerDay Float? @map("penalty_per_day")

  kpiCriteriaId Int?         @map("kpi_criteria_id")
  kpiCriteria   KpiCriteria? @relation(fields: [kpiCriteriaId], references: [id])

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@map("task_kpi_settings")
}

model TaskAttachment {
  id         Int      @id @default(autoincrement())
  taskId     Int      @map("task_id")
  documentId String   @map("document_id")
  type       String   @default("REFERENCE")
  createdAt  DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@map("task_attachments")
}

enum TaskRole {
  OWNER
  ASSIGNEE
  APPROVER
  COORDINATOR
  FOLLOWER
}

model TaskParticipant {
  taskId                 Int      @map("task_id")
  employeeCode           String   @map("employee_code")
  participantRole        TaskRole @map("participant_role")
  assignedAt             DateTime @default(now()) @map("assigned_at")
  contributionPercentage Float    @default(100.0) @map("contribution_percentage")

  task     Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employee Employee @relation("EmployeeTasks", fields: [employeeCode], references: [employeeCode])

  @@id([taskId, employeeCode, participantRole])
  @@map("task_participants")
}

model TaskClosure {
  ancestorId   Int @map("ancestor_id")
  descendantId Int @map("descendant_id")
  depth        Int @map("depth")

  ancestor   Task @relation("TaskClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Task @relation("TaskClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@map("task_closure")
}

model TaskComment {
  id              Int     @id @default(autoincrement())
  taskId          Int     @map("task_id")
  authorCode      String? @map("author_code")
  content         String  @db.Text
  isSystemMessage Boolean @default(false) @map("is_system_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model MasterPlan {
  id          Int     @id @default(autoincrement())
  title       String  @map("title")
  description String? @db.Text
  type        String  @default("SMART_GOAL")

  startDate DateTime? @map("start_date") @db.Date
  endDate   DateTime? @map("end_date") @db.Date
  status    String    @default("ACTIVE")

  departmentId  Int?    @map("department_id")
  createdByCode String? @map("created_by_code")

  documentId String? @map("document_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@map("master_plans")
}

model KpiPeriod {
  id          Int             @id @default(autoincrement())
  name        String          @map("name")
  startDate   DateTime        @map("start_date") @db.Date
  endDate     DateTime        @map("end_date") @db.Date
  evaluations KpiEvaluation[]
  targets     EmployeeKpiTarget[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kpi_periods")
}

model KpiCriteria {
  id            Int     @id @default(autoincrement())
  name          String  @map("name")
  description   String? @db.Text
  categoryId    Int?    @map("category_id")

  settings KpiCriteriaSetting?
  
  details KpiEvaluationDetail[]
  tasks   TaskKpiSetting[]
  targets EmployeeKpiTarget[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("kpi_criteria")
}

model KpiCriteriaSetting {
  criteriaId    Int     @id @map("criteria_id")
  weight        Float   @default(1.0) @map("weight")
  baseScore     Float?  @map("base_score")
  scoringMethod String  @default("MANUAL") @map("scoring_method")

  difficulty           String @default("NORMAL") @map("difficulty")
  difficultyMultiplier Float  @default(1.0) @map("difficulty_multiplier")
  bonusThresholdDays   Int    @default(0) @map("bonus_threshold_days")
  bonusPerDay          Float  @default(0) @map("bonus_per_day")
  penaltyPerDay        Float  @default(0) @map("penalty_per_day")

  integrationCode      String? @map("integration_code")
  formula              String? @map("formula")

  criteria KpiCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)
  @@map("kpi_criteria_settings")
}

model EmployeeKpiTarget {
  id           Int      @id @default(autoincrement())
  employeeCode String   @map("employee_code")
  periodId     Int      @map("period_id")
  criteriaId   Int      @map("criteria_id")
  targetValue  Float    @map("target_value")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employee Employee    @relation("EmployeeKpiTargets", fields: [employeeCode], references: [employeeCode], onDelete: Cascade)
  period   KpiPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  criteria KpiCriteria @relation(fields: [criteriaId], references: [id], onDelete: Cascade)

  @@unique([employeeCode, periodId, criteriaId])
  @@map("employee_kpi_targets")
}

model KpiEvaluation {
  id           Int     @id @default(autoincrement())
  employeeCode String  @map("employee_code")
  periodId     Int     @map("period_id")
  totalScore   Float?  @map("total_score")
  status       String  @default("DRAFT")
  reviewerCode String? @map("reviewer_code")

  employee Employee              @relation("KpiEmployee", fields: [employeeCode], references: [employeeCode])
  reviewer Employee?             @relation("KpiReviewer", fields: [reviewerCode], references: [employeeCode])
  period   KpiPeriod             @relation(fields: [periodId], references: [id])
  details  KpiEvaluationDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kpi_evaluations")
}

model KpiEvaluationDetail {
  id            Int     @id @default(autoincrement())
  evaluationId  Int     @map("evaluation_id")
  criteriaId    Int     @map("criteria_id")
  selfScore     Float?  @map("self_score")
  reviewerScore Float?  @map("reviewer_score")
  notes         String? @db.Text

  evaluation KpiEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  criteria   KpiCriteria   @relation(fields: [criteriaId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("kpi_evaluation_details")
}

model TaskRankTemplate {
  id             Int     @id @default(autoincrement())
  classification String  @map("classification")
  rank           String  @map("rank")
  taskName       String  @map("task_name")
  defaultUnit    String  @map("default_unit")
  defaultWeight  Float?  @map("default_weight")
  rankNameVN     String? @map("rank_name_vn")
  legalBasis     String? @map("legal_basis")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("task_rank_templates")
}

model RankQuota {
  id          Int    @id @default(autoincrement())
  rankCode    String @map("rank_code")
  taskName    String @map("task_name")
  unit        String @map("unit")
  targetValue Float  @map("target_value")
  weight      Float? @map("weight")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("rank_quotas")
}

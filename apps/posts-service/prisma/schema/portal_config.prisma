model PortalConfig {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("portal_configs")
}

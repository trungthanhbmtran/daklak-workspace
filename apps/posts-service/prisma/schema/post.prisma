model Post {
  id                    String   @id @default(uuid())
  title                 String
  description           String?  @db.Text
  content               String?  @db.LongText
  contentJson           String?  @db.LongText @map("content_json") // Lexical format
  slug                  String   @unique
  thumbnail             String?
  authorId              String   @map("author_id")
  
  // Lifecycle & Workflow
  status                String   @default("DRAFT") // DRAFT | SUBMITTED | UNDER_REVIEW | REJECTED | APPROVED | PUBLISHED | UNPUBLISHED | ARCHIVED
  currentVersion        Int      @default(1) @map("current_version")
  
  isFeatured            Boolean  @default(false) @map("is_featured")
  isNotification        Boolean  @default(false) @map("is_notification")
  viewCount             Int      @default(0) @map("view_count")
  
  isTranslated          Boolean  @default(false) @map("is_translated")
  isDeleted             Boolean  @default(false) @map("is_deleted")
  
  // Decree 42 & CMS Fields
  authorName            String?  @map("author_name")
  source                String?
  language              String   @default("vi")
  seoTitle              String?  @map("seo_title")
  seoDescription        String?  @db.Text @map("seo_description")
  seoKeywords           String?  @map("seo_keywords")
  allowComment          Boolean  @default(true) @map("allow_comment")
  
  publishedAt           DateTime? @map("published_at")
  expiredAt             DateTime? @map("expired_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  // Relations
  categoryId            String?   @map("category_id")
  category              Category? @relation(fields: [categoryId], references: [id])
  
  tags                  Tag[]     @relation("PostToTag")
  versions              PostVersion[]
  moderationLogs        ModerationLog[]
  auditLogs             AuditLog[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([isDeleted])
  @@map("posts")
}


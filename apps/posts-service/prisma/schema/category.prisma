model Category {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  parentId        String?  @map("parent_id")
  lft             Int      @default(0)
  rgt             Int      @default(0)
  depth           Int      @default(0)
  status          Boolean  @default(true)
  thumbnail       String?
  linkType        String?  @default("standard") @map("link_type") // standard | static | external
  customUrl       String?  @map("custom_url")
  target          String?  @default("_self") // _self | _blank
  orderIndex      Int      @default(0) @map("order_index")
  description     String?  @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description") @db.Text
  isGovStandard   Boolean  @default(false) @map("is_gov_standard")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent          Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryToCategory")
  posts           Post[]

  @@index([lft, rgt])
  @@index([parentId])
  @@map("posts_categories")
}

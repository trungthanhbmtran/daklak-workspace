model PortalMenu {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  path            String?
  icon            String?
  target          String   @default("_self") // _self | _blank
  parentId        String?  @map("parent_id")
  linkType        String   @default("INTERNAL") // INTERNAL | CATEGORY | EXTERNAL
  position        String   @default("HEADER") // HEADER | SIDEBAR | FOOTER
  orderIndex      Int      @default(0) @map("order_index")
  status          Boolean  @default(true)
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  parent          PortalMenu?  @relation("MenuToMenu", fields: [parentId], references: [id])
  children        PortalMenu[] @relation("MenuToMenu")

  @@index([parentId])
  @@index([position])
  @@map("portal_menus")
}
